# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — реальные секреты никогда не коммитим; *.example — документация, коммитим.
.env
.env.local
.env.*.local
.env.production
.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# uploaded photos (этап 1 — локальное хранилище, см. src/lib/storage.ts)
/public/uploads/*
!/public/uploads/.gitkeep

# PM2 логи
/logs/*
!/logs/.gitkeep

# нормализация git: бэкап старого prod .git и устаревший маркер rsync-деплоя
/.git.legacy-*
.deploy-fast.deps.hash
