// Florist Dashboard — единый дашборд управления заказами.
// Ключевые принципы (см. ТЗ):
//  - раздельные статусы: оплата / заказ / назначение / доставка / синхронизация;
//  - раздельные финансовые поля;
//  - цена флориста фиксируется в заказе снимком в момент назначения;
//  - открытка и заметка клиента хранятся с оригиналами и не меняются автоматически.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────  ENUMS  ─────────────────────────────

enum Role {
  OWNER
  FLORIST
  CALL_CENTER
}

enum Platform {
  WOOCOMMERCE
  SHOPIFY
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  PENDING
}

// Режим аутентификации Shopify конкретного Site. Новый сценарий — CUSTOM_APP
// (Dev Dashboard app + client_credentials, отдельное приложение на каждый магазин).
enum ShopifyAuthMode {
  CUSTOM_APP
}

// Детальный статус подключения Shopify Custom App.
enum ShopifyConnStatus {
  CONNECTING // введены credentials, идёт первичная проверка
  CONNECTED // токен получен, домен и обязательные scopes подтверждены
  DEGRADED // подключён, но не хватает части обязательных scopes
  REAUTH_REQUIRED // credentials больше не действуют (повторный 401 / отзыв secret / удалён app)
  DISCONNECTED // отключён владельцем (история и товары сохранены)
}

// Статус подключения WooCommerce-магазина (отдельно от Shopify — свой жизненный цикл).
enum WooConnStatus {
  CONNECTING // введены credentials, идёт первичная проверка REST API
  CONNECTED // REST API доступен, права read/write подтверждены
  DEGRADED // подключён, но часть прав/эндпоинтов недоступна
  REAUTH_REQUIRED // 401/403 — credentials недействительны или отозваны
  DISCONNECTED // отключён владельцем (история и товары сохранены)
}

enum PaymentStatus {
  UNPAID
  PAID
  PAY_LATER_APPROVED // BNPL (Klarna/Airwallex) авторизован: заказ валиден, оплата поступит позже — НЕ считать неоплатой
  REFUNDED
  PARTIALLY_REFUNDED
}

// Статус самого заказа (жизненный цикл). "Новый" не используется — оплаченный сразу CONFIRMED.
enum OrderStatus {
  AWAITING_PAYMENT
  CONFIRMED
  ASSIGNED
  FLORIST_ACCEPTED
  IN_PROGRESS
  READY
  AWAITING_COURIER
  IN_TRANSIT
  DELIVERED
  PROBLEM
  CANCELLED
}

// Текущее состояние назначения на уровне заказа (отдельно от истории назначений).
enum AssignmentStatus {
  UNASSIGNED // требует назначения (никого нет / все отказались)
  ASSIGNED // назначен, ждём реакции флориста
  ACCEPTED // флорист принял
}

// Состояние конкретной записи назначения (история).
enum AssignmentState {
  ASSIGNED
  ACCEPTED
  DECLINED
  REASSIGNED
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  FAILED
}

// ── BURQ доставка ──
enum DeliveryProvider {
  BURQ
}

// Нормализованный статус попытки доставки (не привязан к строкам Burq).
enum DeliveryProviderStatus {
  DRAFT_PENDING // задача поставлена, черновик ещё не создан
  DRAFT_CREATED // Burq order создан (request), ждёт ручного checkout/dispatch флористом
  SCHEDULED
  COURIER_ASSIGNED
  COURIER_EN_ROUTE_TO_PICKUP
  AT_PICKUP
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  PROBLEM // attempting reroute / disputed — зависшее проблемное состояние (terminal-like для автоматики)
  CANCEL_REQUESTED
  CANCELLED
  FAILED
  RETURNING
  RETURNED
  UNKNOWN
}

// Статус планирования черновика (DeliveryIntent).
enum DeliveryIntentStatus {
  SCHEDULED // задача запланирована (PENDING в outbox)
  WAITING_FOR_FLORIST // доставка сегодня, но флорист не назначен / pickup не готов
  DRAFT_CREATED // черновик успешно создан
  SKIPPED // задача пропущена (не eligible), без ошибки
  FAILED // создание завершилось ошибкой
}

// Источник изменения статуса доставки (для истории/аудита).
enum DeliveryEventSource {
  BURQ_WEBHOOK
  MANUAL_ADMIN
  POLLING
  SYSTEM
}

enum SyncStatus {
  LOCAL // создан внутри системы / тестовый
  SYNCED
  PENDING
  ERROR
}

enum PriceMode {
  AUTO
  MANUAL
}

// Что флорист видит по финансам заказа. Не влияет на видимость чужих цен
// или прибыли владельца — те скрыты от флориста в любом режиме (см. CLAUDE.md).
enum FloristFinanceVisibility {
  MAKER_ONLY // видит только назначенную ему цену изготовления (по умолчанию)
  FULL // дополнительно видит налог, доставку клиента, чаевые и итог клиента
}

enum MessageChannel {
  SMS
  EMAIL
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageParty {
  SENDER
  RECIPIENT
}

// ── QUO (ex-OpenPhone) единая история коммуникаций по заказу ──
enum CommunicationType {
  SMS
  CALL
  VOICEMAIL
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
}

enum CommunicationPartyRole {
  CUSTOMER // телефон покупателя (Order.senderPhone / billing)
  RECIPIENT // телефон получателя доставки (Order.recipientPhone)
  UNKNOWN // не удалось сопоставить роль
}

enum CommunicationStatus {
  PENDING // исходящее создано, ещё не подтверждено провайдером
  SENT
  DELIVERED
  RECEIVED // входящее сообщение
  COMPLETED // завершённый звонок
  MISSED // пропущенный/без ответа звонок
  FAILED
}

enum BackfillMode {
  DRY_RUN
  LIVE
}

enum BackfillStatus {
  RUNNING
  DONE
  FAILED
}

/**
 * История запусков backfill QUO: период, фильтры, режим, статус, счётчики/разбивка, инициатор,
 * время, безопасная ошибка. `activeLock` (@unique) держит один активный LIVE-запуск (защита от гонки/
 * двойного запуска): "ACTIVE" пока идёт LIVE, null после завершения.
 */
model QuoBackfillRun {
  id                String         @id @default(cuid())
  mode              BackfillMode
  status            BackfillStatus @default(RUNNING)
  fromAt            DateTime
  toAt              DateTime
  siteId            String?
  quoPhoneNumberId  String?
  counters          Json? // {found,created,updated,skipped,unlinked,errors}
  breakdown         Json? // {byType:{...}, bySite:{...}}
  initiatedByUserId String?
  startedAt         DateTime       @default(now())
  finishedAt        DateTime?
  safeError         String?
  activeLock        String?        @unique // "ACTIVE" пока идёт LIVE-запуск; null иначе

  @@index([startedAt])
}

// Статус товара — источник истины Shopify (active/draft/archived).
enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

// Тип фоновой синхронизации сайта (универсально для Shopify/WooCommerce).
enum SyncKind {
  PRODUCTS
  ORDERS
}

// Аудитория внутреннего Telegram-уведомления. Один заказ может иметь ОТДЕЛЬНОЕ основное
// сообщение у флористов и у владельца — они не затирают друг друга.
// Назначение бота. Разные боты могут указывать на ОДИН чат — chatId живёт на боте,
// а не на аудитории, поэтому это не создаёт конфликта.
enum TelegramBotPurpose {
  OWNER
  FLORIST
  CUSTOMER_SERVICE
}

enum TelegramAudience {
  FLORIST
  OWNER
}

enum SiteSyncStatus {
  RUNNING
  DONE
  ERROR
}

// ─────────────────────────────  ПОЛЬЗОВАТЕЛИ  ─────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  role         Role
  telegramId   String?
  active       Boolean  @default(true)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  florist     Florist?
  orderAudits OrderAudit[]

  @@index([role])
}

// Профиль флориста (привязан к User с ролью FLORIST).
model Florist {
  id                String                   @id @default(cuid())
  userId            String                   @unique
  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  active            Boolean                  @default(true)
  financeVisibility FloristFinanceVisibility @default(MAKER_ONLY)
  avatarUrl         String? // ссылка на маленькую аватарку (public/uploads); загружает владелец
  createdAt         DateTime                 @default(now())

  sitePriorities SiteFloristPriority[]
  productPrices  FloristProductPrice[]
  currentOrders  Order[]                @relation("CurrentFlorist")
  assignments    OrderAssignment[]
  pickupLocation FloristPickupLocation?
  telegramBot    TelegramBot?
  deliveries     Delivery[]             @relation("DeliveryFlorist")
}

// ─────────────────────────────  САЙТЫ  ─────────────────────────────

model Site {
  id               String           @id @default(cuid())
  name             String
  shortName        String
  platform         Platform
  connectionStatus ConnectionStatus @default(PENDING)
  logo             String?
  colorTag         String           @default("#64748b")
  createdAt        DateTime         @default(now())

  // LEGACY (старый общий OAuth-app): специфичные для магазина поля, полученные при установке.
  // Для нового режима CUSTOM_APP не используются — там всё в зашифрованных полях ниже.
  shopifyShopDomain  String? @unique // "example.myshopify.com"
  shopifyAccessToken String? // shpat_... — LEGACY plain-text (общий OAuth); CUSTOM_APP использует accessTokenEncrypted
  timezone           String? // IANA-таймзона магазина (из Shopify shop.json) — для «сегодня» в списке закупки

  // ── CUSTOM APP (Dev Dashboard app + client_credentials, отдельное приложение на магазин) ──
  // Все секреты — ТОЛЬКО в зашифрованном виде (AES-256-GCM, см. lib/crypto/secretBox).
  authMode                      ShopifyAuthMode? // CUSTOM_APP для новых подключений; null = LEGACY
  normalizedShopDomain          String? // канонический "*.myshopify.com" — идентификатор магазина
  clientIdEncrypted             String?
  clientSecretEncrypted         String?
  clientSecretMask              String? // "********abcd" — для UI без расшифровки
  // Окно ротации Client Secret: старый secret валиден для входящих webhook до previousSecretValidUntil.
  previousClientSecretEncrypted String?
  previousSecretValidUntil      DateTime?
  accessTokenEncrypted          String?
  accessTokenMask               String? // маска токена для UI без расшифровки
  accessTokenExpiresAt          DateTime? // client_credentials: now + 86399s
  apiVersion                    String? // напр. "2026-07"
  grantedScopes                 String[]           @default([]) // фактические scopes из Shopify (не из формы)
  lastConnectionCheckAt         DateTime?
  lastSyncAt                    DateTime?
  shopifyConnStatus             ShopifyConnStatus? // CONNECTING|CONNECTED|DEGRADED|REAUTH_REQUIRED|DISCONNECTED
  connectionError               String? // безопасный текст (без секретов)

  floristPriorities SiteFloristPriority[]
  products          Product[]
  orders            Order[]
  syncs             SiteSync[]
  webhooks          ShopifyWebhook[]
  // WooCommerce: платформенные credentials/настройки вынесены в отдельную 1:1 модель
  // (Shopify-поля выше НЕ переносятся и не рефакторятся).
  wooConnection     WooCommerceConnection?
  wooWebhooks       WooCommerceWebhook[]

  // ── Burq автосоздание черновиков доставки ──
  burqDraftAutoCreateEnabled     Boolean @default(false)
  burqDraftCreationLocalTime     String  @default("04:00") // локальное время (HH:mm) утреннего создания черновиков
  automationDailyLocalTime      String   @default("09:00") // "HH:mm" локального времени ежедневных триггеров автоматизаций (напр. «Доставка сегодня»)
  // Единый текст dropoff-инструкций магазина, автоматически добавляемый во все новые Burq draft.
  // Пусто/NULL → стандартная инструкция выключена (отдельный boolean не нужен).
  burqDefaultDropoffInstructions String?

  // ── QUO (ex-OpenPhone): номер магазина для исходящих SMS ──
  quoPhoneNumberId   String? // QUO phone number id (PN…) — используется как `from` при отправке
  quoPhoneNumber     String? // E.164 номер магазина (для отображения и storePhone)
  quoEnabled         Boolean   @default(false) // QUO включён для магазина (гейт исходящих/входящих)
  quoLastCheckAt     DateTime? // время последней успешной проверки подключения к QUO
  quoConnectionError String? // безопасный текст ошибки последней проверки (без секретов)

  // ── SMS-маркетинг ──
  reviewUrl   String? // ссылка на отзыв для {{review_url}}; пусто → review-правила не отправляются
  automationSites AutomationSite[]

  // Запрет двух активных Site одного платформенного домена (двойное подключение).
  @@unique([platform, normalizedShopDomain])
}

// Прогресс фоновой синхронизации по сайту и типу (товары/заказы). Одна актуальная
// строка на (siteId, kind) — обновляется по ходу импорта, читается UI для прогресса.
model SiteSync {
  id           String         @id @default(cuid())
  siteId       String
  site         Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  kind         SyncKind
  status       SiteSyncStatus @default(RUNNING)
  total        Int? // всего к обработке, если известно (для «X из Y»)
  processed    Int            @default(0)
  created      Int            @default(0)
  updated      Int            @default(0)
  skipped      Int            @default(0)
  errors       Int            @default(0)
  errorMessage String?
  startedAt    DateTime       @default(now())
  finishedAt   DateTime?

  @@unique([siteId, kind])
  @@index([siteId])
}

// Упорядоченный список приоритетов флористов для конкретного сайта.
// position 0 = основной, дальше по возрастанию — резервные.
model SiteFloristPriority {
  id        String  @id @default(cuid())
  siteId    String
  site      Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  floristId String
  florist   Florist @relation(fields: [floristId], references: [id], onDelete: Cascade)
  position  Int

  @@unique([siteId, floristId])
  @@unique([siteId, position])
  @@index([siteId])
}

// ─────────────────────────────  ТОВАРЫ И ЦЕНЫ  ─────────────────────────────

// Карточка товара (агрегат). Точные цены сайта живут в ProductVariant;
// здесь только агрегаты minPrice/maxPrice по активным неудалённым вариантам.
model Product {
  id                        String        @id @default(cuid())
  name                      String
  image                     String?
  defaultFloristComposition String? // шаблон состава букета; НЕ используется в заказе напрямую (только для заполнения вариантов)
  siteId                    String
  site                      Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  externalId                String // Shopify product id
  status                    ProductStatus @default(ACTIVE) // источник истины — Shopify
  productType               String?
  adminUrl                  String? // ссылка на товар в Shopify Admin (у Woo сюда пишется permalink витрины)
  onlineUrl                 String? // публичная ссылка на товар в витрине магазина (Woo: permalink, Shopify: /products/{handle})
  floristPrice              Decimal?      @db.Decimal(10, 2) // базовая себестоимость; NULL = не задана → флорист получает полную стоимость заказа
  minPrice                  Decimal?      @db.Decimal(10, 2) // агрегат по активным вариантам
  maxPrice                  Decimal?      @db.Decimal(10, 2)
  remoteDeleted             Boolean       @default(false) // пропал из внешнего API
  deletedAt                 DateTime?
  lastSyncedAt              DateTime?
  lastSeenSyncRunId         String? // id последнего sync-прогона, где товар встретился (для безопасной пометки remoteDeleted только после DONE)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  variants      ProductVariant[]
  floristPrices FloristProductPrice[]

  @@unique([siteId, externalId])
  @@index([siteId])
}

// Конкретная вариация товара (Shopify variant). Хранится отдельно от Product
// для единой модели даже при единственном варианте "Default Title".
model ProductVariant {
  id                 String    @id @default(cuid())
  productId          String
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  externalId         String // Shopify variant id
  title              String // напр. "Small / Red" или "Default Title"
  sku                String?
  listPrice          Decimal   @db.Decimal(10, 2) // цена сайта
  compareAtPrice     Decimal?  @db.Decimal(10, 2)
  image              String?
  option1            String?
  option2            String?
  option3            String?
  inventoryQty       Int? // если доступно текущими scopes
  available          Boolean   @default(true) // статус доступности
  floristComposition String? // локальный состав букета для флориста (многострочный текст) — Shopify не трогает
  floristPrice       Decimal?  @db.Decimal(10, 2) // необязательная цена флориста для варианта
  position           Int?
  adminUrl           String? // ссылка на вариант в Admin, если доступна
  lastSyncedAt       DateTime?
  lastSeenSyncRunId  String? // см. Product.lastSeenSyncRunId
  remoteDeleted      Boolean   @default(false)
  deletedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  floristPrices FloristProductPrice[]

  @@unique([productId, externalId])
  @@index([productId])
}

// Индивидуальный override цены флориста. variantId = null → override на весь товар;
// заданный variantId → override на конкретный вариант. Приоритет резолва — см.
// modules/pricing/service.ts. UI для флорист-оверрайдов пока не строится (задел на будущее).
model FloristProductPrice {
  id        String          @id @default(cuid())
  productId String
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  floristId String
  florist   Florist         @relation(fields: [floristId], references: [id], onDelete: Cascade)
  makeCost  Decimal         @db.Decimal(10, 2)

  @@unique([floristId, productId, variantId])
  @@index([productId])
  @@index([variantId])
}

// ─────────────────────────────  ЗАКАЗЫ  ─────────────────────────────

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique

  siteId String
  site   Site   @relation(fields: [siteId], references: [id])
  source String // источник заказа (напр. "Website", "Phone")

  // Даты
  externalCreatedAt DateTime // дата создания заказа на сайте
  deliveryDate      DateTime
  deliveryWindow    String // напр. "14:00 – 18:00"

  // Отправитель (billing). Адрес — из Shopify billing_address (двусторонним НЕ является: показываем
  // как есть; при повторной синхронизации не обнуляем). Отдельно от адреса получателя (shipping).
  senderName        String
  senderPhone       String
  senderEmail       String?
  senderAddressLine String?
  senderApartment   String?
  senderCity        String?
  senderProvince    String? // province_code (напр. "OR")
  senderZip         String?
  senderCountry     String? // country_code (напр. "US")

  // Инструкции доставки — native Shopify Local Delivery (Additional details → Delivery instructions).
  // Источник: GraphQL Order.fulfillmentOrders → deliveryMethod.additionalInformation.instructions.
  // НЕ путать с cardMessage (текст открытки) и customerNote (ручная заметка владельца/колл-центра).
  deliveryInstructions String @default("")

  // Получатель
  recipientName  String
  recipientPhone String
  recipientEmail String?
  addressLine    String
  apartment      String?
  city           String
  zip            String

  // Открытка и заметка — с оригиналами, автоматически не меняются
  cardMessage          String @default("")
  originalCardMessage  String @default("")
  customerNote         String @default("")
  originalCustomerNote String @default("")

  // Финансы (раздельно) — доступны только владельцу
  itemsTotal           Decimal @db.Decimal(10, 2)
  tax                  Decimal @default(0) @db.Decimal(10, 2)
  tip                  Decimal @default(0) @db.Decimal(10, 2)
  discount             Decimal @default(0) @db.Decimal(10, 2)
  deliveryCustomerCost Decimal @default(0) @db.Decimal(10, 2)
  customerTotal        Decimal @db.Decimal(10, 2)
  floristTotal         Decimal @default(0) @db.Decimal(10, 2) // снимок суммы флористу
  deliveryActualCost   Decimal @default(0) @db.Decimal(10, 2)
  estimatedProfit      Decimal @default(0) @db.Decimal(10, 2)

  // Пять раздельных статусов
  paymentStatus    PaymentStatus    @default(UNPAID)
  orderStatus      OrderStatus      @default(AWAITING_PAYMENT)
  assignmentStatus AssignmentStatus @default(UNASSIGNED)
  deliveryStatus   DeliveryStatus   @default(PENDING)
  syncStatus       SyncStatus       @default(LOCAL)

  // Назначенный флорист (снимок цены — в floristTotal и в позициях)
  currentFloristId String?
  currentFlorist   Florist?  @relation("CurrentFlorist", fields: [currentFloristId], references: [id])
  priceMode        PriceMode @default(AUTO)

  // Производство и доставка
  readyAt          DateTime?
  bouquetPhotoUrl  String?
  deliveryPhotoUrl String?
  trackingUrl      String?

  // Синхронизация (готовим под интеграции)
  externalId        String?
  platform          Platform
  lastSyncedAt      DateTime?
  externalUpdatedAt DateTime? // Shopify updated_at / Woo date_modified_gmt — защита от out-of-order
  syncError         String?

  // Внешний статус и платёжные данные платформы (заполняются WooCommerce; Shopify не трогает).
  externalStatus        String? // сырой статус платформы: "pending" | "processing" | ...
  paymentMethod         String? // order.payment_method (напр. "airwallex_klarna")
  paymentMethodTitle    String? // order.payment_method_title (напр. "Klarna Pay Later")
  paymentClassification String? // результат classifyWooPayment: PAID|PAY_LATER_APPROVED|PAYMENT_PENDING|PAYMENT_FAILED|REFUNDED|UNKNOWN
  paymentWarning        String? // безопасное предупреждение владельцу (без PII), если статус неоднозначен
  // Внешнее удаление/архивация (order.deleted / trash): физически заказ НЕ удаляем.
  remoteDeleted         Boolean   @default(false)
  deletedAt             DateTime?

  // true — заказ подтянут разовым backfill-скриптом истории Shopify (не через
  // "живой" вебхук). Используется, чтобы показывать его в отдельной вкладке
  // "Старые заказы", а не смешивать с обычной лентой (см. scripts/backfill-shopify-orders.ts).
  isBackfilled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          OrderItem[]
  assignments    OrderAssignment[]
  messages       Message[]
  communications OrderCommunication[]
  deliveryIntent DeliveryIntent?
  deliveries     Delivery[]
  telegramMessages TelegramMessage[]
  audits         OrderAudit[]
  automationJobs AutomationJob[]

  // NULL допустим много раз (Postgres: NULL != NULL) — не мешает заказам без внешнего источника.
  // Источник истины для идемпотентности вебхуков (см. ingestShopifyOrder) — не полагаемся
  // только на проверку в коде перед созданием.
  @@unique([siteId, externalId])
  @@index([siteId])
  @@index([deliveryDate])
  @@index([currentFloristId])
  @@index([orderStatus])
  @@index([isBackfilled])
}

model OrderItem {
  id                         String  @id @default(cuid())
  orderId                    String
  order                      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  // Ссылки/снимки на товар и вариант. Свободные строки (не FK) — снимок должен
  // переживать физическое исчезновение товара/варианта; резолв цены — по этим id.
  productId                  String? // наш Product.id (для авто-цены)
  variantId                  String? // наш ProductVariant.id (для авто-цены варианта)
  productExternalId          String? // снимок Shopify product id
  variantExternalId          String? // снимок Shopify variant id
  name                       String // снимок названия товара
  variantName                String? // снимок названия варианта
  sku                        String? // снимок SKU
  // Снимки изображений. `image` — LEGACY «эффективное» изображение (variant ?? product):
  // сохранено для старых заказов, где разделить parent/variant задним числом невозможно.
  // Новые импорты пишут все три: parentImageUrl/variantImageUrl раздельно + image как прежде.
  image                      String? // legacy/effective snapshot — не удалять, читается как fallback
  parentImageUrl             String? // фото родительского товара (Product.image)
  variantImageUrl            String? // фото выбранной вариации (ProductVariant.image), если задано
  floristCompositionSnapshot String? // снимок состава варианта на момент заказа (не Shopify description)
  quantity                   Int     @default(1)
  options                    String  @default("") // выбранные параметры (текст)
  externalPrice              Decimal @db.Decimal(10, 2) // цена покупателю за позицию (только владелец)
  floristItemPrice           Decimal @default(0) @db.Decimal(10, 2) // снимок цены флориста за позицию

  @@index([orderId])
}

// История назначений заказа флористам. Активное состояние заказа — в Order.assignmentStatus.
model OrderAssignment {
  id                   String          @id @default(cuid())
  orderId              String
  order                Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  floristId            String
  florist              Florist         @relation(fields: [floristId], references: [id], onDelete: Cascade)
  state                AssignmentState @default(ASSIGNED)
  priceMode            PriceMode       @default(AUTO)
  floristTotalSnapshot Decimal         @default(0) @db.Decimal(10, 2)
  assignedAt           DateTime        @default(now())
  respondedAt          DateTime?

  @@index([orderId])
  @@index([floristId])
}

// ─────────────────────────────  СООБЩЕНИЯ (тестовые на этапе 1)  ─────────────────────────────

model Message {
  id        String           @id @default(cuid())
  orderId   String
  order     Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  channel   MessageChannel
  direction MessageDirection
  party     MessageParty
  body      String
  createdAt DateTime         @default(now())

  @@index([orderId])
}

/**
 * Единая история коммуникаций по заказу (QUO/OpenPhone): SMS, звонки, voicemail. Привязка к
 * заказу — на уровне КОНКРЕТНОГО события по нормализованному телефону + дате (orderId nullable:
 * непривязанные события живут в разделе «Нераспознанные коммуникации»). Идемпотентность — по
 * (provider, providerEventId). Секреты/сырой webhook целиком НЕ храним (только нужные метаданные).
 */
model OrderCommunication {
  id      String  @id @default(cuid())
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  provider               String  @default("QUO")
  providerEventId        String? // QUO webhook event id (EV…) — ключ идемпотентности
  providerResourceId     String? // message/call id (AC…) — для дозагрузки записи/транскрипта
  providerConversationId String? // conversation id (CN…)
  providerUserId         String? // QUO user (US…), кто звонил/ответил/отправил
  providerPhoneNumberId  String? // QUO phone number id магазина (PN…)

  type      CommunicationType
  direction CommunicationDirection
  partyRole CommunicationPartyRole @default(UNKNOWN)
  status    CommunicationStatus

  storePhone              String? // номер магазина, через который прошла коммуникация (E.164)
  externalPhone           String // отображаемый номер собеседника
  externalPhoneNormalized String // E.164 для сопоставления

  messageText     String? // текст SMS
  durationSeconds Int? // длительность звонка
  recordingUrl    String? // ссылка на запись (QUO)
  transcript      String? // транскрипт звонка (Business/Scale)
  summary         String? // краткое содержание звонка (Business/Scale)
  attachmentsJson Json? // MMS/вложения [{url,type}]
  rawMetadata     Json? // компактные доп. поля события (без секретов/сырого payload целиком)

  occurredAt  DateTime // время события в QUO
  deliveredAt DateTime? // подтверждение доставки исходящего
  readAt      DateTime? // глобальное (командное) прочтение входящего/пропущенного
  ignoredAt   DateTime? // «Игнорировать» для нераспознанных (исчезает из активного списка)

  // Исходящие: устойчивый app-level ключ идемпотентности (двойной клик/повтор формы → без дублей).
  sendKey      String? @unique
  sentByUserId String? // кто из сотрудников админки отправил (User.id), для исходящих

  automationJobs AutomationJob[] // авто-SMS job'ы, чьё сообщение записано в эту коммуникацию

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerEventId])
  @@index([orderId, occurredAt])
  @@index([externalPhoneNormalized, occurredAt])
  @@index([providerResourceId])
  @@index([orderId, readAt])
}

// Зарегистрированные Shopify webhook-подписки по Site — чтобы не создавать дубли и
// хранить внешние ID/статус. Одна запись на (siteId, topic).
model ShopifyWebhook {
  id               String   @id @default(cuid())
  siteId           String
  site             Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  topic            String // напр. "ORDERS_CREATE"
  shopifyWebhookId String? // GID подписки в Shopify
  status           String   @default("ACTIVE") // ACTIVE | FAILED | DELETED
  lastError        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([siteId, topic])
  @@index([siteId])
}

// ─────────────────────────────  WOOCOMMERCE  ─────────────────────────────
//
// Платформенные credentials и настройки WooCommerce — отдельная 1:1 модель к Site.
// Shopify-поля остаются inline в Site и НЕ рефакторятся (Shopify уже на production).
// Все секреты — ТОЛЬКО зашифрованы (AES-256-GCM, тот же lib/crypto/secretBox, что и Shopify).

model WooCommerceConnection {
  id     String @id @default(cuid())
  siteId String @unique
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // URL нормализуется сервером: только HTTPS, без credentials/query/hash, без trailing slash.
  // @unique — DB-гарантия, что один магазин нельзя подключить дважды (идемпотентность подключения).
  storeUrl   String @unique // "https://example.com"
  apiBaseUrl String // storeUrl + "/wp-json/" + apiVersion — собирается сервером
  apiVersion String @default("wc/v3")

  consumerKeyEncrypted    String
  consumerSecretEncrypted String
  consumerSecretMask      String // "********abcd" — для UI без расшифровки
  // Уникальный webhook secret этого Site (генерируем сами, НЕ равен consumer secret).
  webhookSecretEncrypted  String?

  connStatus      WooConnStatus @default(CONNECTING)
  connectionError String? // безопасный текст (без секретов/PII)

  storeName  String?
  currency   String?
  timezone   String?
  wooVersion String?
  wpVersion  String?

  lastConnectionCheckAt DateTime?
  lastProductSyncAt     DateTime?
  lastOrderSyncAt       DateTime?

  // Конфигурируемый маппинг «внутреннее поле Floremart → Woo meta key». JSON, per-Site.
  // Напр. { "deliveryDate": "_delivery_date", "cardMessage": "card_message" }.
  orderMetaMapping Json?

  // ── Airwallex / Klarna BNPL (см. classifyWooPayment) ── ничего не хардкодим.
  airwallexEnabled                 Boolean  @default(false)
  klarnaPayLaterPendingIsConfirmed Boolean  @default(false)
  airwallexPaymentMethodIds        String[] @default([]) // напр. ["airwallex_klarna", "airwallex_paylater"]
  airwallexMetaKeys                Json? // { "paymentIntentStatus": "_airwallex_payment_status", ... }
  payLaterMaxWaitMinutes           Int      @default(1440) // сколько ждём финального статуса, иначе предупреждение
  unknownBehavior                  String   @default("HOLD") // HOLD | AWAITING_PAYMENT — поведение при UNKNOWN

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Зарегистрированные WooCommerce webhook-подписки по Site. Отдельно от ShopifyWebhook:
// у платформ разные external ID/topics/HMAC/жизненный цикл (общий интерфейс — на уровне
// TS-адаптера, хранение раздельное). Одна запись на (siteId, topic).
model WooCommerceWebhook {
  id             String    @id @default(cuid())
  siteId         String
  site           Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  topic          String // "order.created" | "product.updated" | ...
  externalId     String? // id вебхука в WooCommerce
  deliveryUrl    String
  status         String    @default("ACTIVE") // ACTIVE | FAILED | DELETED
  lastDeliveryAt DateTime?
  lastError      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([siteId, topic])
  @@index([siteId])
}

// ─────────────────────────────  ДОСТАВКА (BURQ)  ─────────────────────────────
//
// Черновики Burq создаются автоматически (отложенная outbox-задача), но курьер и платная
// доставка оформляются флористом вручную в кабинете Burq (checkout_url). Секреты Burq — в env.

// Точка забора флориста (pickup). 1:1 Florist в v1 (архитектурно расширяемо до нескольких).
model FloristPickupLocation {
  id                  String   @id @default(cuid())
  floristId           String   @unique
  florist             Florist  @relation(fields: [floristId], references: [id], onDelete: Cascade)
  locationName        String
  contactName         String
  contactPhone        String // E.164
  addressLine         String
  apartmentOrSuite    String?
  city                String
  state               String // 2-буквенный US-код
  zip                 String
  courierInstructions String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Планирование черновика: версия расписания для anti-stale отложенных задач. 1:1 Order.
model DeliveryIntent {
  id                   String               @id @default(cuid())
  orderId              String               @unique
  order                Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  scheduleVersion      Int                  @default(0) // ++ при каждом перепланировании
  scheduledAvailableAt DateTime? // когда задача должна выполниться (UTC)
  intentStatus         DeliveryIntentStatus @default(SCHEDULED)
  lastSkipReason       String? // FLORIST_NOT_ASSIGNED | PICKUP_NOT_CONFIGURED | PICKUP_INACTIVE | PICKUP_INVALID | ...
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

// Одна попытка доставки (attempt). Несколько исторических на Order; актуальна ровно одна
// (partial unique index isCurrentAttempt=true — добавлен в migration.sql, Prisma-схемой не выражается).
model Delivery {
  id                String           @id @default(cuid())
  orderId           String
  order             Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider          DeliveryProvider @default(BURQ)
  floristId         String? // флорист, чей pickup использован
  florist           Florist?         @relation("DeliveryFlorist", fields: [floristId], references: [id])
  pickupLocationId  String? // снимок id использованной точки забора
  expectedFloristId String? // ожидаемый флорист на момент старта POST (защита от гонки)
  attemptNumber     Int              @default(1)
  isCurrentAttempt  Boolean          @default(true)

  externalDeliveryId String? // Burq order id
  externalOrderRef   String? // наш external_order_ref, переданный в Burq
  checkoutUrl        String? // ссылка кабинета Burq (чувствительная — доступ флориста)
  isDraft            Boolean @default(true)

  status            DeliveryProviderStatus @default(DRAFT_PENDING)
  rawProviderStatus String?
  providerEventAt   DateTime? // время последнего применённого provider-события (anti-rollback)

  idempotencyKey           String? // x-idempotency-key внешнего POST
  quoteAmount              Decimal?  @db.Decimal(10, 2)
  currency                 String?
  // Фактическая стоимость доставки Uber из Burq (Path A: после dispatch, из latest_delivery).
  finalCost                Decimal?  @db.Decimal(10, 2) // total_amount_due (или fee) в долларах
  finalCostUpdatedAt       DateTime?
  quoteId                  String? // latest_delivery.quote_id
  providerName             String? // latest_delivery.provider (напр. "uber")
  providerExternalId       String? // latest_delivery.provider_id (стабильный id провайдера)
  costSource               String? // "BURQ_FINAL" (Path A) | (в будущем "UBER_QUOTE")
  trackingUrl              String?
  courierName              String?
  courierPhone             String?
  estimatedPickupAt        DateTime?
  estimatedDeliveryAt      DateTime?
  pickedUpAt               DateTime?
  deliveredAt              DateTime?
  cancelledAt              DateTime?
  cancellationReason       String? // FLORIST_REASSIGNED | MANUAL_ADMIN | ...
  failureCode              String?
  failureMessageSafe       String?
  proofOfDeliveryUrl       String? // @deprecated — не используется; оставлено для обратной совместимости
  // Proof of Delivery (Path A, первая версия — храним Burq URL как есть, без копирования в наше хранилище).
  proofOfDeliveryUrls      Json? // массив URL фото подтверждения доставки (proof_of_delivery_image_urls)
  signatureImageUrl        String? // signature_image_url (если когда-либо запрошен)
  proofOfDeliveryFetchedAt DateTime?

  // Переназначение/суперседанс попыток (историю не переписываем).
  supersedesDeliveryId   String?
  supersededByDeliveryId String?

  resolutionSource DeliveryEventSource?
  resolvedByUserId String?

  lastWebhookAt     DateTime?
  lastStatusCheckAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  statusEvents DeliveryStatusEvent[]

  @@index([orderId])
  @@index([externalDeliveryId])
}

// История статусов доставки (без полного payload и PII).
model DeliveryStatusEvent {
  id               String                  @id @default(cuid())
  deliveryId       String
  delivery         Delivery                @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  providerEventId  String? // id события Burq (для дедупа)
  rawStatus        String?
  normalizedStatus DeliveryProviderStatus
  source           DeliveryEventSource
  userId           String? // сотрудник (для MANUAL_ADMIN)
  previousStatus   DeliveryProviderStatus?
  newStatus        DeliveryProviderStatus?
  safeReason       String?
  occurredAt       DateTime? // provider event time
  receivedAt       DateTime                @default(now())
  createdAt        DateTime                @default(now())

  @@unique([deliveryId, providerEventId]) // дедуп webhook-события по (delivery, providerEventId)
  @@index([deliveryId])
}

// ─────────────────────────────  OUTBOX / ФОНОВЫЕ СОБЫТИЯ  ─────────────────────────────
//
// Персистентный transactional outbox: доменные события сохраняются ДО обработки, чтобы
// не терялись при рестарте процесса (в отличие от in-process шины). Отдельный worker
// (scripts/outbox-worker.ts) поллит эту таблицу с lock/lease, ретраями и dead-letter.
// Модели ADDITIVE — существующие таблицы не затрагиваются. См. docs/OUTBOX_AND_WORKER.md.

enum OutboxStatus {
  PENDING // ждёт обработки
  PROCESSING // взято worker'ом (lease), в работе
  PROCESSED // успешно обработано
  FAILED // временный сбой, будет повтор (attempts < maxAttempts)
  DEAD_LETTER // исчерпаны попытки — требует ручного вмешательства
}

model OutboxEvent {
  id             String       @id @default(cuid())
  eventType      String // напр. "order.delivery.completed"
  aggregateType  String // напр. "order"
  aggregateId    String // напр. Order.id
  payload        Json // тонкий payload события (без PII сверх необходимого)
  idempotencyKey String       @unique // дедуп публикации: одно событие = одна запись
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  maxAttempts    Int          @default(8)
  availableAt    DateTime     @default(now()) // не брать раньше этого времени (backoff)
  lockedAt       DateTime? // когда взято в обработку (для восстановления зависших)
  lockedBy       String? // идентификатор worker'а, держащего lease
  processedAt    DateTime?
  lastError      String? // последняя БЕЗОПАСНАЯ ошибка (без PII/секретов)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Поллинг worker'а: выбираем доступные PENDING/FAILED по availableAt.
  @@index([status, availableAt])
  // Восстановление зависших PROCESSING по lockedAt.
  @@index([status, lockedAt])
  @@index([aggregateType, aggregateId])
}

// Универсальный guard идемпотентности провайдер-операций: гарантирует, что конкретное
// побочное действие (отправка SMS/Telegram, Shopify/Woo fulfillment, создание Burq-доставки)
// выполняется РОВНО один раз, даже при повторной доставке события. Проверяется до действия.
model ProcessedOperation {
  id           String   @id @default(cuid())
  operationKey String   @unique // напр. "order.delivery.completed:<orderId>:sms"
  kind         String // напр. "sms.send", "telegram.send", "shopify.fulfillment"
  externalId   String? // id результата у провайдера (напр. message id), если есть
  createdAt    DateTime @default(now())

  @@index([kind])
}

/**
 * Отправленное внутреннее Telegram-уведомление. Хранит message_id, чтобы обновлять
 * существующее сообщение (editMessage) вместо создания дубля.
 *
 * `dedupeKey` включает роль/аудиторию, поэтому у одного заказа независимо живут основное
 * сообщение флористам ("order:{id}:florist") и владельцу ("order:{id}:owner"), а срочные
 * уведомления владельцу получают собственные ключи и НЕ затирают основное.
 *
 * chatId/messageId — строки: id супергрупп у Telegram — большие отрицательные числа, и хранение
 * строкой исключает потерю точности; над этими значениями арифметика не нужна.
 */
model TelegramMessage {
  id        String           @id @default(cuid())
  dedupeKey String           @unique
  audience  TelegramAudience
  chatId    String
  messageId String
  orderId   String?
  order     Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  // Каким ботом отправлено — без этого не понять, чьим токеном редактировать.
  botId     String?
  bot       TelegramBot?     @relation(fields: [botId], references: [id], onDelete: SetNull)
  eventType String
  lastText  String? // последний отправленный текст — не редактируем, если он не изменился
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([orderId])
}

/**
 * Бот Telegram. У каждого флориста СВОЙ бот и свой личный чат: бот не может редактировать
 * сообщение, отправленное другим ботом, поэтому «одно сообщение на заказ» существует в
 * пределах одного бота, а не всей системы.
 *
 * Токен — только зашифрованным (secretBox). Включение возможно лишь после успешной проверки:
 * любое изменение токена или чата сбрасывает verifiedAt и enabled.
 */
model TelegramBot {
  id             String             @id @default(cuid())
  label          String
  purpose        TelegramBotPurpose
  tokenEncrypted String?
  botUsername    String?
  chatId         String?
  floristId      String?            @unique // заполнено только у purpose = FLORIST
  florist        Florist?           @relation(fields: [floristId], references: [id], onDelete: Cascade)
  enabled        Boolean            @default(false)
  verifiedAt     DateTime?
  lastErrorSafe  String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  messages TelegramMessage[]

  @@index([purpose])
}

/**
 * Настройки внутренних Telegram-уведомлений (singleton, id="singleton").
 * Заменяют конфигурацию через .env: владелец задаёт всё из дашборда.
 *
 * Секрет хранится ТОЛЬКО зашифрованным (AES-256-GCM, lib/crypto/secretBox) — в UI токен
 * обратно никогда не отдаётся, показывается лишь факт «настроен».
 *
 * `enabled` можно включить лишь после успешной проверки: verifiedAt заполняется при удачном
 * getMe + тестовых сообщениях. Любое изменение токена или чата сбрасывает verifiedAt и enabled,
 * иначе можно было бы оставить включённым заведомо нерабочий конфиг.
 */
model TelegramSettings {
  id                String    @id @default("singleton")
  botTokenEncrypted String?
  ownerChatId       String?
  floristsChatId    String?
  enabled           Boolean   @default(false)
  verifiedAt        DateTime?
  botUsername       String? // из getMe — показываем владельцу, что подключён нужный бот
  lastErrorSafe     String? // безопасная причина последней неудачи, без секретов
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ─────────────────────────────  BURQ SETTINGS  ─────────────────────────────
//
// Глобальные настройки интеграции Burq (единственная строка, id="singleton").
// Секреты (API Key, Webhook Secret) хранятся ТОЛЬКО в зашифрованном виде (AES-256-GCM,
// см. lib/crypto/secretBox); в UI отдаётся лишь маска. Открытый текст нигде не логируется.
//
// enabled — интеграция настроена/включена (приём webhook, connection check).
// draftCreationEnabled — ОТДЕЛЬНЫЙ гейт авто-создания доставок; ВЫКЛ до подтверждения sandbox.
enum BurqEnvironment {
  SANDBOX
  PRODUCTION
}

model BurqSettings {
  id                     String          @id @default("singleton")
  environment            BurqEnvironment @default(SANDBOX)
  apiKeyEncrypted        String?
  apiKeyMask             String? // "********abcd" — для UI без расшифровки
  webhookSecretEncrypted String?
  webhookSecretMask      String?
  apiBaseUrl             String? // advanced override; по умолчанию официальный URL
  enabled                Boolean         @default(false)
  draftCreationEnabled   Boolean         @default(false) // гейт авто-создания draft (OFF до sandbox)
  lastConnectionCheckAt  DateTime?
  connectionStatus       String? // "ok" | "unauthorized" | "error" | "saved_not_checked"
  connectionErrorSafe    String? // безопасное сообщение, без секретов
  // Глобальные order-level dimensions для Burq (обязательны в Create Order V2). Настраиваемые.
  packageLength          Float?
  packageWidth           Float?
  packageHeight          Float?
  packageWeight          Float?
  dimensionUnit          String          @default("in") // "in" | "cm"
  weightUnit             String          @default("lb") // "lb" | "kg" | "g"
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
}

// Аудит действий с настройками Burq. БЕЗ секретов — только кто/что/когда/окружение.
model BurqSettingsAudit {
  id          String          @id @default(cuid())
  userId      String
  action      String // "save_credentials" | "toggle_enabled" | "change_environment" | "connection_check" | "toggle_draft_creation"
  environment BurqEnvironment
  detailSafe  String? // безопасная деталь без секретов (напр. "enabled=true")
  createdAt   DateTime        @default(now())

  @@index([createdAt])
}

/**
 * Аудит ручного редактирования полей заказа сотрудниками (owner/call-center/florist).
 * Пишется в ТОЙ ЖЕ транзакции, что и обновление заказа (см. updateOrderBlock). `changed`
 * содержит ТОЛЬКО before/after изменившихся полей блока — без паролей, токенов, секретов
 * и полного payload. Отдельного UI просмотра пока нет (только запись).
 */
model OrderAudit {
  id        String   @id @default(cuid())
  orderId   String
  userId    String
  role      Role
  block     String // contacts | sender | status | delivery | cardNote
  changed   Json // { field: { from, to } } — только изменённые поля
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
  @@index([userId, createdAt])
}

/**
 * Зашифрованные секреты интеграций (глобально, не per-Site). Одна строка = один секрет.
 * Значение — только в зашифрованном виде (AES-256-GCM, lib/crypto/secretBox). В UI отдаётся
 * ТОЛЬКО `maskedSuffix` (маска), полное значение из браузера недоступно. Сейчас используется для
 * QUO webhook signing secrets (provider="QUO", kind="webhook_signing_secret"); модель обобщаемая.
 */
model IntegrationSecret {
  id             String   @id @default(cuid())
  provider       String // "QUO"
  kind           String // "webhook_signing_secret"
  encryptedValue String // AES-256-GCM payload (никогда не отдаётся в браузер)
  maskedSuffix   String // "********abcd" — только для UI
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([provider, kind, active])
}

// ─────────────────────────────  SMS-МАРКЕТИНГ  ─────────────────────────────
//
// Движок правил авто-SMS: SmsAutomation (правило) + SmsAutomationJob (задача + история).
// Отложенное исполнение — через существующий durable outbox (availableAt), отдельной очереди НЕТ.
// Реальная отправка — через sendOrderSms (номер Site, запись OrderCommunication). Всё ADDITIVE.
// triggerType — String + централизованный app-registry (src/modules/sms/triggers.ts): новый
// триггер добавляется без Prisma-миграции; неизвестное значение показывается как «Unsupported»
// и не запускается. Все правила после deploy выключены (active=false), seed-правил нет.

enum SmsAudience {
  CUSTOMER
  RECIPIENT
  BOTH
}

// Адресат конкретного job'а — строго один из двух. BOTH разворачивается в per-recipient job'ы,
// поэтому записать BOTH в job by design нельзя (отдельный enum, а не SmsAudience).
enum SmsRecipientType {
  CUSTOMER
  RECIPIENT
}

enum SmsDelayUnit {
  IMMEDIATE
  MINUTE
  HOUR
  DAY
  WEEK
  MONTH
}

enum SmsJobStatus {
  SCHEDULED
  PROCESSING
  SENT
  SKIPPED
  FAILED
  CANCELLED
}

// Канал доставки автоматизации. SMS — первый и пока единственный; расширяется (EMAIL/PUSH/…)
// БЕЗ изменения модели Automation — через ChannelSender-реестр (src/modules/automations/channels).
enum AutomationChannel {
  SMS
}

model Automation {
  id             String            @id @default(cuid())
  name           String
  active         Boolean           @default(false) // после deploy все правила выключены
  channel        AutomationChannel @default(SMS) // канал доставки (пока только SMS)
  triggerType    String // валидируется app-registry; строкой — для расширяемости без миграции
  audience       SmsAudience
  delayAmount    Int               @default(0)
  delayUnit      SmsDelayUnit      @default(IMMEDIATE)
  template       String // текст шаблона inline (отдельная Template-сущность — фаза 2)
  conditionsJson Json? // расширяемые условия (нормализованные AutomationCondition — фаза 2)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime? // soft-delete при наличии истории

  jobs  AutomationJob[]
  // Магазины правила (many-to-many): одно правило — один шаблон на несколько Site.
  sites AutomationSite[]

  @@index([triggerType, active])
}

// Связка «правило ↔ магазин». Единственный источник правды о магазинах автоматизации
// (Automation.siteId удалён миграцией 20260722120000_automation_multi_site).
model AutomationSite {
  automationId String
  siteId       String

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  site       Site       @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([automationId, siteId])
  @@index([siteId])
}

model AutomationJob {
  id           String     @id @default(cuid())
  automationId String
  // Restrict: правило с историей нельзя удалить физически (только soft-delete) — job'ы сохраняются.
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Restrict)
  orderId      String
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  recipientType   SmsRecipientType // только CUSTOMER | RECIPIENT
  phoneNormalized String // E.164 адресата (для дедупа BOTH и истории)
  scheduledAt     DateTime // когда worker должен отправить (delay применён)
  status          SmsJobStatus     @default(SCHEDULED)

  renderedTextSnapshot String? // фиксируется в момент фактической отправки (рендер по свежим данным)
  idempotencyKey       String              @unique // automationId:orderId:recipientType:triggerOccurrence
  communicationId      String? // ссылка на созданный OrderCommunication (если отправлено)
  communication        OrderCommunication? @relation(fields: [communicationId], references: [id], onDelete: SetNull)

  sentAt            DateTime?
  skippedAt         DateTime?
  failedAt          DateTime?
  lastErrorSafe     String? // без PII/секретов
  providerMessageId String? // id сообщения у провайдера (для SMS — QUO)
  attempts          Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  executionLogs AutomationExecutionLog[]

  @@index([status, scheduledAt])
  @@index([automationId, status])
  @@index([orderId])
  @@index([communicationId])
}

// Глобальный «рубильник» автоматизаций (singleton, id="singleton"). При disableAll=true новые
// job'ы не создаются и не отправляются. Строка создаётся лениво при первом переключении (без seed).
model AutomationSettings {
  id              String   @id @default("singleton")
  disableAll      Boolean  @default(false)
  updatedByUserId String?
  updatedAt       DateTime @updatedAt
}

// Журнал выполнения — только для РЕАЛЬНО созданных Job. Пошаговая трассировка (scheduled →
// picked → rendered → provider_accepted → sent/skipped/failed) для быстрой диагностики.
// Без секретов/полного provider payload (только detailSafe).
model AutomationExecutionLog {
  id           String        @id @default(cuid())
  jobId        String
  job          AutomationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  automationId String
  orderId      String?
  stage        String // scheduled | picked | rendered | provider_accepted | sent | skipped | failed
  detailSafe   String? // безопасная деталь (причина skip, safe error, provider message id) — без PII/секретов
  createdAt    DateTime      @default(now())

  @@index([jobId, createdAt])
  @@index([automationId, createdAt])
}
